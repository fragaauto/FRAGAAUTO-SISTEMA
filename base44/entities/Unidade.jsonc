{
  "name": "Unidade",
  "type": "object",
  "properties": {
    "nome": {
      "type": "string",
      "description": "Nome da unidade (ex: Auto Portas, Lava Jato)"
    },
    "status": {
      "type": "string",
      "enum": [
        "ativo",
        "inativo"
      ],
      "default": "ativo"
    }
  },
  "required": [
    "nome"
  ]
}