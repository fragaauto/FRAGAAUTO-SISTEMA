{
  "name": "Configuracao",
  "type": "object",
  "properties": {
    "unidade_id": {
      "type": "string",
      "description": "ID da unidade a que esta configura\u00e7\u00e3o pertence"
    },
    "nome_empresa": {
      "type": "string"
    },
    "endereco": {
      "type": "string"
    },
    "telefone": {
      "type": "string"
    },
    "email": {
      "type": "string"
    },
    "logo_url": {
      "type": "string"
    },
    "cnpj": {
      "type": "string"
    },
    "site": {
      "type": "string"
    },
    "instagram": {
      "type": "string"
    },
    "whatsapp_atendimento": {
      "type": "string"
    },
    "mensagem_link_cliente": {
      "type": "string"
    },
    "mensagem_remarketing": {
      "type": "string"
    },
    "mensagem_orcamento": {
      "type": "string",
      "description": "Template de mensagem para follow-up de or\u00e7amentos"
    },
    "formas_pagamento": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "ativa": {
            "type": "boolean"
          }
        }
      }
    },
    "taxas_pagamento": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "forma": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "taxa_percentual": {
            "type": "number"
          }
        }
      }
    },
    "parcelas_credito": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "parcelas": {
            "type": "number"
          },
          "taxa_percentual": {
            "type": "number"
          }
        }
      }
    },
    "impostos": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "nome": {
            "type": "string"
          },
          "percentual": {
            "type": "number"
          },
          "ativo": {
            "type": "boolean"
          }
        }
      }
    },
    "condicoes_especiais": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "tipo_gatilho": {
            "type": "string",
            "enum": [
              "valor",
              "itens"
            ],
            "default": "valor"
          },
          "valor_minimo": {
            "type": "number"
          },
          "itens_minimos": {
            "type": "number"
          },
          "tipo": {
            "type": "string",
            "enum": [
              "desconto",
              "parcelamento",
              "brinde"
            ]
          },
          "descricao": {
            "type": "string"
          },
          "valor_desconto_percentual": {
            "type": "number"
          },
          "parcelas_sem_juros": {
            "type": "number"
          },
          "brinde": {
            "type": "string"
          },
          "ativa": {
            "type": "boolean"
          }
        }
      }
    },
    "status_atendimento_personalizados": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "valor": {
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "cor": {
            "type": "string"
          }
        }
      }
    },
    "cliente_nome_obrigatorio": {
      "type": "boolean",
      "default": true
    },
    "cliente_telefone_obrigatorio": {
      "type": "boolean",
      "default": true
    },
    "cliente_cpf_obrigatorio": {
      "type": "boolean",
      "default": false
    },
    "cliente_nascimento_obrigatorio": {
      "type": "boolean",
      "default": false
    },
    "cliente_endereco_obrigatorio": {
      "type": "boolean",
      "default": false
    },
    "os_placa_obrigatorio": {
      "type": "boolean",
      "default": true
    },
    "os_modelo_obrigatorio": {
      "type": "boolean",
      "default": true
    },
    "os_km_obrigatorio": {
      "type": "boolean",
      "default": false
    },
    "os_observacoes_veiculo_obrigatorio": {
      "type": "boolean",
      "default": false
    },
    "os_queixa_obrigatorio": {
      "type": "boolean",
      "default": false
    },
    "os_tecnico_obrigatorio": {
      "type": "boolean",
      "default": false
    },
    "os_atribuicao_servico_obrigatoria": {
      "type": "boolean",
      "default": false
    },
    "dias_minimos_reenvio": {
      "type": "number"
    },
    "dias_validade_oferta": {
      "type": "number"
    },
    "oferta_padrao_remarketing": {
      "type": "string"
    },
    "condicao_pagamento_remarketing": {
      "type": "string"
    },
    "restringir_periodo_producao_proprio": {
      "type": "boolean",
      "default": false,
      "description": "Se verdadeiro, usu\u00e1rios comuns s\u00f3 veem produ\u00e7\u00e3o no per\u00edodo pr\u00e9-configurado"
    },
    "periodo_producao_proprio_inicio": {
      "type": "string",
      "format": "date",
      "description": "Data inicial fixa para visualiza\u00e7\u00e3o da produ\u00e7\u00e3o individual"
    },
    "periodo_producao_proprio_fim": {
      "type": "string",
      "format": "date",
      "description": "Data final fixa para visualiza\u00e7\u00e3o da produ\u00e7\u00e3o individual"
    },
    "restringir_horario_acesso": {
      "type": "boolean",
      "default": false,
      "description": "Se verdadeiro, usu\u00e1rios comuns s\u00f3 acessam o sistema no hor\u00e1rio permitido"
    },
    "horario_acesso_inicio": {
      "type": "string",
      "description": "Hor\u00e1rio inicial permitido (HH:MM)"
    },
    "horario_acesso_fim": {
      "type": "string",
      "description": "Hor\u00e1rio final permitido (HH:MM)"
    },
    "dias_acesso_permitidos": {
      "type": "array",
      "description": "Dias da semana permitidos (0=Dom..6=S\u00e1b). Vazio = todos os dias",
      "items": {
        "type": "number"
      },
      "default": [
        1,
        2,
        3,
        4,
        5,
        6
      ]
    },
    "lembrete_checklist_ativo": {
      "type": "boolean",
      "default": false
    },
    "lembrete_checklist_intervalo": {
      "type": "number",
      "default": 30
    },
    "lembrete_checklist_whatsapp": {
      "type": "string"
    },
    "agenda_google_sheets_id": {
      "type": "string"
    },
    "agenda_google_sheets_aba": {
      "type": "string"
    },
    "agenda_google_calendar_id": {
      "type": "string"
    },
    "agenda_google_api_key": {
      "type": "string"
    },
    "agenda_sheets_col_data": {
      "type": "string"
    },
    "agenda_sheets_col_hora": {
      "type": "string"
    },
    "agenda_sheets_col_cliente": {
      "type": "string"
    },
    "agenda_sheets_col_servico": {
      "type": "string"
    },
    "agenda_sheets_col_placa": {
      "type": "string"
    },
    "agenda_sheets_col_obs": {
      "type": "string"
    },
    "evolution_api_url": {
      "type": "string"
    },
    "evolution_api_key": {
      "type": "string"
    },
    "evolution_instance": {
      "type": "string"
    },
    "modulos_ativos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [
        "atendimentos",
        "financeiro",
        "estoque",
        "clientes",
        "agenda",
        "remarketing",
        "relatorios",
        "checklist"
      ]
    }
  },
  "required": [
    "nome_empresa"
  ]
}